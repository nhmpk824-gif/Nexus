{
  "name": "nexus",
  "private": true,
  "version": "0.0.0",
  "description": "Nexus desktop AI companion built with Electron, React, and TypeScript.",
  "author": "Nexus Team",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:47821 && cross-env DESKTOP_PET_USE_DEV_SERVER=1 electron .\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "node --experimental-strip-types --test .\\tests\\audio-providers.test.ts .\\tests\\browser-vad.test.ts .\\tests\\text-files.test.ts .\\tests\\performance.test.ts .\\tests\\voice-core.test.ts .\\tests\\voice-session.test.ts .\\tests\\wakeword-runtime.test.ts .\\tests\\tool-registry.test.ts .\\tests\\tool-assistant.test.ts .\\tests\\tool-planner.test.ts .\\tests\\reminder-intent.test.ts .\\tests\\reminder-schedule.test.ts .\\tests\\lyrics-search.test.ts .\\tests\\search-content-extract.test.ts .\\tests\\background-search.test.ts .\\tests\\chat-runtime.test.ts .\\tests\\web-search-runtime.test.ts .\\tests\\storage-settings.test.ts .\\tests\\memory.test.ts .\\tests\\memory-archive.test.ts .\\tests\\failover.test.ts",
    "preview": "vite preview",
    "start:app": "npm run build && electron .",
    "smoke": "npm run build && cross-env SMOKE_TEST=1 electron .",
    "smoke:packaged": "cross-env SMOKE_TEST=1 .\\release\\win-unpacked\\Nexus.exe",
    "package": "npm run package:win",
    "package:dir": "npm run build && electron-builder --dir --config.win.signAndEditExecutable=false",
    "package:win": "npm run build && electron-builder --win nsis --config.win.signAndEditExecutable=false",
    "package:win:signed": "npm run build && electron-builder --win nsis",
    "verify:release": "npm run lint && npm test && npm run package:dir && npm run smoke:packaged && npm run package:win"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@ricky0123/vad-web": "^0.0.30",
    "onnxruntime-web": "^1.24.3",
    "pinyin-pro": "^3.28.0",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^6.5.10",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sherpa-onnx-node": "^1.11.3",
    "tesseract.js": "^7.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^36.2.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "ai.factory.desktoppet",
    "productName": "Nexus",
    "directories": {
      "output": "release"
    },
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "!node_modules/onnxruntime-node/bin/napi-v3/darwin/**",
      "!node_modules/onnxruntime-node/bin/napi-v3/linux/**",
      "!node_modules/onnxruntime-node/bin/napi-v3/win32/arm64/**"
    ],
    "extraResources": [
      {
        "from": "sherpa-models",
        "to": "sherpa-models",
        "filter": [
          "**/*",
          "!**/*.tar.bz2",
          "!**/test_wavs/**",
          "!sherpa-onnx-streaming-paraformer-bilingual-zh-en/encoder.onnx",
          "!sherpa-onnx-streaming-paraformer-bilingual-zh-en/decoder.onnx",
          "!sherpa-onnx-kws-zipformer-gigaspeech-3.3M-2024-01-01/*.int8.onnx",
          "!sherpa-onnx-kws-zipformer-wenetspeech-3.3M-2024-01-01/*epoch-99-avg-1*.onnx",
          "!sherpa-onnx-kws-zipformer-wenetspeech-3.3M-2024-01-01/*.int8.onnx"
        ]
      }
    ],
    "asarUnpack": [
      "node_modules/sherpa-onnx-node/**",
      "electron/mediaSession.ps1"
    ],
    "icon": "public/nexus.ico",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/nexus.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Nexus"
    }
  }
}
